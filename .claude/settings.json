{
  "outputStyle": "swift-mentor",
  "defaultMode": "auto",
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/build-check.sh",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
